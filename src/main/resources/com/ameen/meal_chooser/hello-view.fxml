<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" prefWidth="480.0" prefHeight="500.0"
      style="-fx-background-color: #f8fafc; -fx-padding: 30;"
      xmlns:fx="http://themeasurement.com/fxml" fx:controller="com.ameen.meal_chooser.HelloController">

    <VBox alignment="CENTER" spacing="5">
        <Label text="غدانا اليوم 🎲" style="-fx-text-fill: #2e3d52; -fx-font-weight: bold;">
            <font>
                <Font name="Segoe UI" size="28.0"/>
            </font>
        </Label>
        <Label text="مقترح الوجبات الذكي لإدارة طعامك اليومي" style="-fx-text-fill: #64748b;">
            <font>
                <Font name="Segoe UI" size="13.0"/>
            </font>
        </Label>
    </VBox>

    <VBox alignment="CENTER" prefHeight="100.0" maxWidth="Infinity"
          style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-color: #e2e8f0; -fx-border-radius: 15; -fx-border-width: 1; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 5); -fx-padding: 15;">
        <Label fx:id="mealDisplayLabel" text="اضغط على زر الاقتراح لبدء الاختيار ✨" textAlignment="CENTER"
               wrapText="true"
               style="-fx-text-fill: #e67e22; -fx-font-weight: bold;">
            <font>
                <Font name="Segoe UI" size="18.0"/>
            </font>
        </Label>
    </VBox>

    <VBox spacing="8" alignment="CENTER_RIGHT">
        <Label text="إضافة وجبة جديدة:" style="-fx-text-fill: #475569; -fx-font-weight: bold;">
            <font>
                <Font name="Segoe UI" size="14.0"/>
            </font>
        </Label>
        <HBox spacing="10" alignment="CENTER">
            <Button text="➕ إضافة" onAction="#onAddMealClick" prefHeight="38.0" prefWidth="90.0"
                    style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <TextField fx:id="newMealInput" promptText="اكتب اسم الطبخة هنا..." prefHeight="38.0" HBox.hgrow="ALWAYS"
                       style="-fx-background-radius: 8; -fx-border-radius: 8; -fx-border-color: #cbd5e1; -fx-background-color: white; -fx-padding: 0 10 0 10; -fx-alignment: center_right;"/>
        </HBox>
    </VBox>

    <VBox spacing="12" alignment="CENTER" maxWidth="Infinity">

        <Button text="🎲 اقترح لي وجبة" onAction="#onSuggestMealClick" prefHeight="45.0" maxWidth="Infinity"
                style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(230,126,34,0.2), 8, 0, 0, 4);">
            <font>
                <Font name="Segoe UI" size="16.0"/>
            </font>
        </Button>

        <HBox spacing="12" alignment="CENTER" maxWidth="Infinity">
            <Button text="🗑️ حذف وجبة" onAction="#onDeleteMealClick" prefHeight="38.0" HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    style="-fx-background-color: #f1f5f9; -fx-text-fill: #ef4444; -fx-border-color: #fca5a5; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"/>

            <Button text="📂 تصفح وإدارة الوجبات" onAction="#onBrowseMealsClick" prefHeight="38.0" HBox.hgrow="ALWAYS"
                    maxWidth="Infinity"
                    style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>

    </VBox>

</VBox>