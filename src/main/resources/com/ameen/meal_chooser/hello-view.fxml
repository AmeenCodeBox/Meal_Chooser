<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ameen.meal_chooser.HelloController"
      style="-fx-background-color: #f4f4f4;">

    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0"/>
    </padding>

    <Label text="غدانا اليوم 🍽️" textFill="#2c3e50">
        <font>
            <Font name="System Bold" size="22.0"/>
        </font>
    </Label>

    <Label fx:id="mealDisplayLabel" text="شو رح نطبخ اليوم ؟" textAlignment="CENTER" textFill="#16a085" wrapText="true">
        <font>
            <Font size="18.0"/>
        </font>
    </Label>

    <Button text="🎲 اقترح لي وجبة" onAction="#onGenerateMealClick"
            style="-fx-background-color: #e67e22; -fx-text-fill: white; -fx-cursor: hand;">
        <font>
            <Font name="System Bold" size="16.0"/>
        </font>
    </Button>

    <Label text="__________________________________________" textFill="#bdc3c7"/>

    <HBox alignment="CENTER" spacing="10.0">
        <TextField fx:id="newMealInput" promptText="اكتب اسم وجبة جديدة هنا..." prefWidth="200.0"
                   style="-fx-padding: 8px;"/>

        <Button text="➕ إضافة" onAction="#onAddMealClick"
                style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 8px 15px;">
            <font>
                <Font name="System Bold" size="13.0"/>
            </font>
        </Button>

        <Button text="🗑️ حذف" onAction="#onDeleteMealClick"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-cursor: hand; -fx-padding: 8px 12px;">
            <font>
                <Font name="System Bold" size="13.0"/>
            </font>
        </Button>
    </HBox>

</VBox>